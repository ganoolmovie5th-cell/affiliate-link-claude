# =============================================================
# HargaBandingin Scraper — Environment Variables
# Copy file ini menjadi .env lalu isi nilai-nilainya
# =============================================================

# ── Firecrawl ─────────────────────────────────────────────────
# Dapatkan API key di: https://www.firecrawl.dev/dashboard
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase Admin SDK ────────────────────────────────────────
# Buat Service Account di Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxx\n-----END PRIVATE KEY-----\n"

# ── Scraper Config ────────────────────────────────────────────
# Interval scraping dalam jam (default: 6)
SCRAPE_INTERVAL_HOURS=6
